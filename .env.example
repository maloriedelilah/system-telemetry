# ---------------------------------------------------------------------------
# system-telemetry per-machine config.  Copy to .env and edit.  NEVER commit .env.
# Same schema on Linux and Windows (msys/mingw bash).
# ---------------------------------------------------------------------------

# --- MQTT broker (homehub = HAOS Mosquitto) --------------------------------
MQTT_HOST=192.168.68.76
MQTT_PORT=1883
MQTT_USER=gpu-telemetry
MQTT_PASS=CHANGE_ME
# HA's discovery prefix is the DEFAULT "homeassistant" even though the instance
# is named cooperhome. Leave this unless you've changed it in HA.
MQTT_DISCOVERY_PREFIX=homeassistant

# --- Identity --------------------------------------------------------------
# Friendly name used in entity ids/names. Defaults to the OS hostname if unset.
TELEMETRY_HOST_NAME=

# --- Roles: turn each collector on (1) or off (0) --------------------------
# nvidia-smi GPU metrics. 1 on any box with NVIDIA cards; 0 on Arc-only boxes.
TELEMETRY_NVIDIA=1
# LibreHardwareMonitor host stats (CPU/RAM/disk temps). Windows boxes with LHM.
TELEMETRY_LHM=0
# Include GPUs reported by LHM (for cards with no nvidia-smi, e.g. Arc B580).
# Leave 0 on NVIDIA boxes so their cards aren't double-published.
LHM_GPUS=0
# Linux host stats (CPU/RAM/disk) via psutil + lm-sensors. The Linux counterpart
# to TELEMETRY_LHM; ignored on Windows. NVMe temp works out of the box; SATA temps
# need `sudo modprobe drivetemp`.
TELEMETRY_HOST=0

# --- LibreHardwareMonitor (only if TELEMETRY_LHM=1) ------------------------
LHM_URL=http://localhost:8085/data.json
# Comma-separated GPU-name substrings to include (e.g. Arc). Empty = all GPUs.
LHM_GPU_INCLUDE=

# --- Loaded-model labels: ollama | lmstudio | none -------------------------
MODEL_SOURCE=none
MODEL_API_URL=http://127.0.0.1:11434
MODEL_API_PATH=/api/v0/models
# Locality filter for LM Studio `lms link` cross-box leakage. Empty = all.
MODEL_FILTER=

# --- Runtime ---------------------------------------------------------------
# Set (seconds) for a long-running loop -> used by the Windows/NSSM service.
# LEAVE BLANK on Linux: the systemd timer handles cadence (single-shot runs).
LOOP_INTERVAL=
# 1 for verbose stderr.
DEBUG=0
